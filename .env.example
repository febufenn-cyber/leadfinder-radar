# LeadFinder configuration — copy to .env and fill in what you have.
# Everything has a working local default except Telegram (console fallback).

ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://leadfinder:leadfinder@localhost:5442/leadfinder
REDIS_URL=redis://localhost:6380/0

# Telegram alerts. Leave empty -> alerts log to console instead.
# 1) Create a bot: message @BotFather -> /newbot -> copy the token.
# 2) Get your chat id: send your new bot any message, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and read result[].message.chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Descriptive User-Agent per Reddit API guidelines (be identifiable)
REDDIT_USER_AGENT=leadfinder/0.1 (personal keyword monitor; contact febinwilliam@gmail.com)

# Reddit OAuth (STRONGLY recommended — unauthenticated search.rss is throttled hard).
# Create a "script" app at https://www.reddit.com/prefs/apps while logged into YOUR
# account; client id is under the app name, secret is labeled. Empty -> RSS fallback.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Threads official API (M3). Create a Meta app with the Threads use case at
# developers.facebook.com, generate a long-lived access token for YOUR account.
# Empty -> Threads polling disabled. Budget: keyword-search quotas are limited
# per day — verify current limits in the Threads API docs before raising these.
THREADS_ACCESS_TOKEN=
THREADS_DAILY_QUERY_BUDGET=48
THREADS_MIN_INTERVAL_MINUTES=15

# Claude CLI (Max OAuth — run `claude /login` once on this host). Tiers per DESIGN §3.
CLAUDE_CLI_PATH=claude
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
CLAUDE_STANDARD_MODEL=claude-sonnet-4-6
CLASSIFY_TIMEOUT_SECONDS=90

POLL_INTERVAL_MINUTES=2
PACKS_DIR=packs
